{
  "name": "lola-cms",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "api:check": "node scripts/check-backend-openapi-drift.mjs && node scripts/check-openapi-contract.mjs && node scripts/check-generated-client.mjs",
    "api:generate": "orval --config orval.config.ts",
    "api:sync:local": "node scripts/check-backend-openapi-drift.mjs --backend-directory ../Lola_backend --write && npm run api:generate",
    "dev": "vite",
    "build": "npm run api:check && vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "lint": "eslint . --max-warnings=0 && npm run architecture:check",
    "architecture:check": "node scripts/check-iam-authority.mjs",
    "test": "vitest run",
    "test:scripts": "node --test scripts/*.test-node.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:api": "VITE_DATA_MODE=api VITE_API_BASE_URL=http://127.0.0.1:3000/api/v1 playwright test --project=api-chromium",
    "test:e2e:iam": "VITE_DATA_MODE=api VITE_API_BASE_URL=http://127.0.0.1:3000/api/v1 playwright test --project=api-chromium e2e/iam-*.spec.ts"
  },
  "dependencies": {
    "@primeuix/themes": "^1.2.5",
    "@simplewebauthn/browser": "^13.3.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "ajv": "^8.20.0",
    "axios": "^1.18.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.15",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^27.2.0",
    "orval": "^7.21.0",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.5"
  },
  "overrides": {
    "fast-uri": "3.1.4"
  }
}
