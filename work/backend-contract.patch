+  /**
+   * Links invitations created before the CMS account existed. Case-insensitive matching is
+   * intentional, while existing membership email values are left untouched to avoid a migration.
+   */
+  private async linkProjectMemberships(user: AdminUser): Promise<void> {
+    const email = (user.email ?? (user.login.includes('@') ? user.login : '')).trim().toLowerCase();
+    if (!email) return;
+    const candidates = await this.prisma.projectMember.findMany({
+      where: { adminUserId: null, email: { equals: email, mode: 'insensitive' } },
+      select: { id: true, projectId: true },
+    });
+    if (!candidates.length) return;
+    const projectIds = candidates.map((membership) => membership.projectId);
+    const existing = await this.prisma.projectMember.findMany({
+      where: { adminUserId: user.id, projectId: { in: projectIds } },
+      select: { projectId: true },
+    });
+    const alreadyLinked = new Set(existing.map((membership) => membership.projectId));
+    const ids = candidates
+      .filter((membership) => !alreadyLinked.has(membership.projectId))
+      .map((membership) => membership.id);
+    if (ids.length) {
+      await this.prisma.projectMember.updateMany({
+        where: { id: { in: ids }, adminUserId: null },
+        data: { adminUserId: user.id },
+      });
+    }
+  }
