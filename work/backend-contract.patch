+import assert from 'node:assert/strict';
+import test from 'node:test';
+import { Body, Controller, Post } from '@nestjs/common';
+import { Test } from '@nestjs/testing';
+import {
+  ApiExtraModels,
+  ApiOkResponse,
+  ApiTags,
+  DocumentBuilder,
+  SwaggerModule,
+} from '@nestjs/swagger';
+import { swaggerOperationIdFactory } from '../src/common/openapi.js';
+import { CmsLoginDto } from '../src/modules/auth/dto/cms-auth.dto.js';
+import { CmsAuthResponseDto } from '../src/modules/auth/dto/cms-auth-response.dto.js';
+import { ScenarioActionDto } from '../src/modules/platform/dto/platform.dto.js';
+
+@ApiTags('contract fixture')
+@ApiExtraModels(CmsLoginDto, CmsAuthResponseDto, ScenarioActionDto)
+@Controller('contract-fixture')
+class ContractFixtureController {
+  @Post('login')
+  @ApiOkResponse({ type: CmsAuthResponseDto })
+  login(@Body() dto: CmsLoginDto): CmsLoginDto {
+    return dto;
+  }
+
+}
+
+void test('OpenAPI exposes stable operation ids and non-empty safe key schemas', async () => {
+  const module = await Test.createTestingModule({ controllers: [ContractFixtureController] }).compile();
+  const app = module.createNestApplication();
+  await app.init();
+  try {
+    const document = SwaggerModule.createDocument(
+      app,
+      new DocumentBuilder().setTitle('contract').setVersion('1').build(),
+      { operationIdFactory: swaggerOperationIdFactory },
+    );
+    assert.equal(document.paths['/contract-fixture/login']?.post?.operationId, 'ContractFixture_login');
+    const schemas = document.components?.schemas ?? {};
+    const authProperties = (schemas.CmsAuthResponseDto as { properties?: Record<string, unknown> })
+      ?.properties;
+    assert.deepEqual(schemas.CmsLoginDto?.required, ['login', 'password']);
+    assert.ok(Object.keys(authProperties ?? {}).length > 0);
+    assert.equal(authProperties?.passwordHash, undefined);
+    assert.deepEqual(schemas.ScenarioActionType?.enum, [
+      'SHOW_ASSISTANT',
+      'HIDE_ASSISTANT',
+      'OPEN_CHAT',
+      'CLOSE_CHAT',
+      'SAY',
+      'PLAY_ANIMATION',
+      'HIGHLIGHT_ELEMENT',
+      'REMOVE_HIGHLIGHT',
+      'SHOW_CTA',
+      'OPEN_PAGE',
+      'OPEN_MODAL',
+      'TRACK',
+      'COMPLETE_SCENARIO',
+    ]);
+  } finally {
+    await app.close();
+  }
+});

