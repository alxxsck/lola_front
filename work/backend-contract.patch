+import assert from 'node:assert/strict';
+import test from 'node:test';
+import { ForbiddenException, type ExecutionContext } from '@nestjs/common';
+import { CmsProjectGuard } from '../src/modules/auth/cms-project.guard.js';
+
+const contextFor = (request: Record<string, unknown>): ExecutionContext =>
+  ({
+    switchToHttp: () => ({ getRequest: () => request }),
+  }) as unknown as ExecutionContext;
+
+void test('CMS project guard allows an admin with a linked membership', async () => {
+  const prisma = {
+    projectMember: {
+      findFirst: ({ where }: { where: Record<string, unknown> }) => {
+        assert.deepEqual(where, { projectId: 'project-a', adminUserId: 'admin-a' });
+        return Promise.resolve({ id: 'membership-a' });
+      },
+    },
+  };
+  const guard = new CmsProjectGuard(prisma as never);
+  const allowed = await guard.canActivate(
+    contextFor({ params: { projectId: 'project-a' }, adminPrincipal: { userId: 'admin-a' } }),
+  );
+  assert.equal(allowed, true);
+});
+
+void test('CMS project guard rejects cross-project access', async () => {
+  const prisma = { projectMember: { findFirst: () => Promise.resolve(null) } };
+  const guard = new CmsProjectGuard(prisma as never);
+  await assert.rejects(
+    guard.canActivate(
+      contextFor({ params: { projectId: 'project-b' }, adminPrincipal: { userId: 'admin-a' } }),
+    ),
+    ForbiddenException,
+  );
+});
