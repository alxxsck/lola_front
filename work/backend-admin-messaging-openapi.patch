+import { ApiProperty, ApiPropertyOptional } from '@nestjs/swagger';
+
+const jsonSchema = { type: 'object' as const, additionalProperties: true };
+
+export class AdminMessageThreadResponseDto {
+  @ApiProperty({ type: String, format: 'uuid' }) id!: string;
+  @ApiProperty({ type: String, format: 'uuid' }) projectId!: string;
+  @ApiProperty({ type: String, format: 'uuid' }) endUserId!: string;
+  @ApiPropertyOptional({ type: String, format: 'uuid', nullable: true }) sessionId!: string | null;
+  @ApiPropertyOptional({ type: String, nullable: true }) title!: string | null;
+  @ApiProperty({ enum: ['OPEN', 'CLOSED'], enumName: 'ThreadStatus' }) status!: 'OPEN' | 'CLOSED';
+  @ApiProperty({ type: String, format: 'date-time' }) createdAt!: string;
+  @ApiProperty({ type: String, format: 'date-time' }) updatedAt!: string;
+}
+
+export class AdminStoredMessageResponseDto {
+  @ApiProperty({ type: String, format: 'uuid' }) id!: string;
+  @ApiProperty({ type: String, format: 'uuid' }) threadId!: string;
+  @ApiProperty({
+    enum: ['USER', 'ASSISTANT', 'ADMIN', 'SCENARIO', 'SYSTEM'],
+    enumName: 'MessageRole',
+  })
+  role!: 'USER' | 'ASSISTANT' | 'ADMIN' | 'SCENARIO' | 'SYSTEM';
+  @ApiProperty({ enum: ['WRITING', 'COMPLETED', 'FAILED'], enumName: 'MessageStatus' })
+  status!: 'WRITING' | 'COMPLETED' | 'FAILED';
+  @ApiProperty({ type: String }) text!: string;
+  @ApiPropertyOptional({ ...jsonSchema, nullable: true }) content!: Record<string, unknown> | null;
+  @ApiProperty({ type: 'array', items: {} }) commands!: unknown[];
+  @ApiProperty(jsonSchema) metadata!: Record<string, unknown>;
+  @ApiPropertyOptional({ type: String, nullable: true }) provider!: string | null;
+  @ApiPropertyOptional({ type: String, nullable: true }) model!: string | null;
+  @ApiPropertyOptional({ type: Number, nullable: true }) inputTokens!: number | null;
+  @ApiPropertyOptional({ type: Number, nullable: true }) outputTokens!: number | null;
+  @ApiPropertyOptional({ type: String, nullable: true }) clientMessageId!: string | null;
+  @ApiPropertyOptional({
+    type: String,
+    nullable: true,
+    description: 'Internal idempotency fingerprint returned by the current service.',
+  })
+  idempotencyKey!: string | null;
+  @ApiProperty({ type: String, format: 'date-time' }) createdAt!: string;
+  @ApiProperty({ type: String, format: 'date-time' }) updatedAt!: string;
+  @ApiProperty({ type: AdminMessageThreadResponseDto }) thread!: AdminMessageThreadResponseDto;
+}
+
+export class SendAdminMessageResponseDto {
+  @ApiProperty({
+    type: Boolean,
+    description: 'True when the same Idempotency-Key was already processed.',
+  })
+  duplicate!: boolean;
+  @ApiProperty({ type: AdminStoredMessageResponseDto }) message!: AdminStoredMessageResponseDto;
+  @ApiProperty({ type: [String], format: 'uuid' }) commandIds!: string[];
+}
